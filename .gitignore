# MindMirror Skill — Git Ignore

# OS
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# Editors / IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# Logs / temp
*.log
*.tmp
*.bak

# Local secrets (just in case anyone adds env)
.env
.env.local
.env.*.local

# Python (if anyone adds eval scripts later)
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/

# Node (if anyone adds tooling later)
node_modules/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Build artifacts
dist/
build/
*.egg-info/

# Personal notes / drafts not for publishing
DRAFTS/
NOTES.md
TODO.private.md
